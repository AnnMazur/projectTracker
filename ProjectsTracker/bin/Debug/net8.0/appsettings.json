{
  "Security": {
    "TrustedOrigins": [
      "http://localhost:3000",
      "https://localhost:7299"
    ],
    "EnableCors": true,
    "EnableSecurityHeaders": true
  },
  "RateLimit": {
    "GeneralPermitLimit": 100,
    "GeneralWindowSeconds": 60,
    "CreatePermitLimit": 10,
    "CreateWindowSeconds": 60,
    "EnableRateLimiting": true
  },
  "Mode": {
    "Environment": "Development",
    "VerboseErrors": true,
    "DetailedLogging": true
  },
  "Logging": {
    "Level": "Debug",
    "LogRateLimitHits": true
  }
}